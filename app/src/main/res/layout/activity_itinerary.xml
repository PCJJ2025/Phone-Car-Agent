<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="行程规划"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#212121" />

    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/weatherScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E8F0FE"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/weatherBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="出发地点"
                android:textSize="14sp"
                android:textColor="#666666" />

            <EditText
                android:id="@+id/etStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:layout_marginTop="6dp"
                android:textSize="14sp"
                android:maxLines="1"
                android:inputType="text"
                android:hint="比如：北京西站 / 当前所在地" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="想做什么？"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/etRequest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:gravity="top"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:layout_marginTop="6dp"
                android:textSize="14sp"
                android:inputType="textMultiLine"
                android:hint="比如：中午想吃和牛土豆，喝杯茶汤，下午做个spa，晚上回家睡觉" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="出发时间"
                        android:textSize="14sp"
                        android:textColor="#666666" />

                    <EditText
                        android:id="@+id/etStartTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:padding="12dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="6dp"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:inputType="text"
                        android:hint="12:00" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="终途地点"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/etEnd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:layout_marginTop="6dp"
                android:textSize="14sp"
                android:maxLines="1"
                android:inputType="text"
                android:hint="比如：家 / 国贸，终点位置" />

            <Button
                android:id="@+id/btnPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="规划行程"
                android:backgroundTint="#FF8F00"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="14sp"
                android:textColor="#212121"
                android:lineSpacingExtra="4dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnRouteMap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="查看路线地图 🗺"
                android:backgroundTint="#1A73E8"
                android:textColor="#FFFFFF"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnSendCar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="发送到车机 🚗"
                android:backgroundTint="#34A853"
                android:textColor="#FFFFFF"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
